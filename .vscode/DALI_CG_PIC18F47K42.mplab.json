            "provider": "microchip.toolchains:xc8@3.10",
            "properties": {
                "HI-TECH-COMP.asmlist": true,
                "HI-TECH-COMP.define-macros": "DALI_USE_DEVICE_TYPE_6;DALI_USE_DEVICE_TYPE_8;DALI_USE_EXTRA_MEMORY_BANKS",
                "HI-TECH-COMP.disable-optimizations": false,
                "HI-TECH-COMP.extra-include-directories": "dali_library;dali_library/dali_core;dali_library/dali_core/dali_dev_type_6;dali_library/dali_core/dali_dev_type_8;dali_library/dali_core/dali_general_cg_core;dali_library/dali_core/dali_hal;lamp_hardware;lamp_hardware/lamp_hw_dev_type_6;drivers_peripherals;DALI_CG_PIC18F47K42.X/mcc_generated_files;DALI_CG_PIC18F47K42.X",
                "HI-TECH-COMP.favor-optimization-for": "-speed,+space",
                "HI-TECH-COMP.identifier-length": "255",
