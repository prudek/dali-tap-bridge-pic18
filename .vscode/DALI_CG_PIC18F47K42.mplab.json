                "HI-TECH-LINK.data-model-size-of-float-gcc": "no-short-float",
                "HI-TECH-LINK.display-class-usage": false,
                "HI-TECH-LINK.display-hex-usage": false,
                "HI-TECH-LINK.display-overall-usage": true,
                "HI-TECH-LINK.display-psect-usage": false,
                "HI-TECH-LINK.fill-flash-options-how": "0",
                "HI-TECH-LINK.fill-flash-options-inc-const": "1",
                "HI-TECH-LINK.fill-flash-options-what": "0",
                "HI-TECH-LINK.format-hex-file-for-download": false,
                "HI-TECH-LINK.initialize-data": true,
                "HI-TECH-LINK.keep-generated-startup.as": false,
