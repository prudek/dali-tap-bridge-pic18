                "XC8-config-global.gcc-opt-std": "--std=c89",
                "XC8-config-global.gcc-output-file-format": "dwarf-3",
                "XC8-config-global.output-file-format": "-mcof,+elf",
                "XC8-config-global.stack-size-high": "auto",
                "XC8-config-global.stack-size-low": "auto",
                "XC8-config-global.stack-size-main": "auto",
                "XC8-config-global.stack-type": "compiled"
