                "HI-TECH-COMP.optimization-assembler": true,
                "HI-TECH-COMP.optimization-assembler-files": false,
                "HI-TECH-COMP.optimization-debug": false,
                "HI-TECH-COMP.optimization-invariant-enable": false,
